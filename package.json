{
  "name": "stock-trade-local-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on tcp:5173 && electron electron/main.cjs\"",
    "dev:web": "vite",
    "dev:electron": "wait-on tcp:5173 && electron electron/main.cjs",
    "dev:server": "node server/index.cjs",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "build": "tsc -b && vite build",
    "start": "node server/index.cjs",
    "test": "node --test electron/services.test.cjs",
    "docker:build": "docker build -t chenpinetree/stocktradehistory:latest .",
    "docker:push": "docker push chenpinetree/stocktradehistory:latest",
    "docker:release": "npm run docker:build && npm run docker:push",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "antd": "^6.3.7",
    "better-sqlite3": "^12.9.0",
    "dayjs": "^1.11.20",
    "echarts": "^6.0.0",
    "iconv-lite": "^0.7.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^37.10.3",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  }
}
